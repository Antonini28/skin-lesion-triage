# ─────────────────────────────────────────────────
#  Backend environment variables
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────────

# Hugging Face Hub — repository containing the 3 model checkpoints.
# Create a free account at https://huggingface.co and upload:
#   student_quantised_int8.pt, rl_threshold_policy.pt, threshold_config.json
HF_REPO_ID=YOUR_HF_USERNAME/skin-lesion-triage-models

# CORS — set to your Vercel frontend URL after deploying
FRONTEND_URL=https://skin-lesion-triage.vercel.app

# Where HF Hub downloads are cached (writable path on Render free tier)
MODEL_CACHE_DIR=/tmp/models
